# Drew AI — Server environment variables
# Copy this file to .env and fill in your values
# !! Never commit .env to version control !!

# Primary provider: Hugging Face Inference Providers
AI_PROVIDER=huggingface
HF_API_KEY=hf_your_token_here
HF_BASE_URL=https://router.huggingface.co/v1/chat/completions
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct:fastest

# Optional legacy fallback: LM Studio
LM_STUDIO_URL=http://127.0.0.1:1234/v1/chat/completions
LM_MODEL=deepseek-r1-distill-qwen-1.5b

# Port the proxy server listens on (Vite proxies /api/* here)
PORT=3001
